- name: installing mutliple packages
  hosts: local
  connection: local
  become: true
  tasks:
    - name: installing packages
      ansible.builtin.package:
        name: "{{ item.name}}"
        state: "{{ item.state }}"
      loop:
        - { name: nginx, state: absent }
        - { name: mysql-server, state: present }
        - { name: redis , state: present }